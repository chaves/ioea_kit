{
	"name": "ioea-sveltekit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"prebuild": "prisma generate && (npx tsx scripts/generate-program-image.ts all || echo 'PDF conversion skipped (tools not available)')",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node server.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"generate-placeholders": "node scripts/generate-placeholders.js",
		"generate-images": "npx tsx scripts/generate-program-image.ts all"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/nodemailer": "^7.0.11",
		"autoprefixer": "^10.5.0",
		"postcss": "^8.5.14",
		"svelte": "^5.55.7",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^3.4.19",
		"tsx": "^4.22.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.3"
	},
	"optionalDependencies": {
		"@img/sharp-darwin-arm64": "^0.34.5",
		"@img/sharp-darwin-x64": "^0.34.5",
		"@img/sharp-linux-x64": "^0.34.5"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@prisma/client",
			"@prisma/engines",
			"esbuild",
			"prisma",
			"sharp"
		]
	},
	"dependencies": {
		"@prisma/adapter-mariadb": "^7.8.0",
		"@prisma/client": "^6.19.3",
		"@types/bcryptjs": "^2.4.6",
		"bcryptjs": "^3.0.3",
		"dotenv": "^17.4.2",
		"marked": "^17.0.6",
		"mysql2": "^3.22.3",
		"nodemailer": "^7.0.13",
		"prisma": "^6.19.3",
		"sharp": "^0.34.5",
		"xlsx": "^0.18.5"
	}
}
